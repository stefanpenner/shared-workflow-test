{
  "name": "reusable-workflows-shadow-testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shadow-test a reusable-workflows PR against a real consumer under an authentic pull_request event.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node --test test/*.test.ts",
    "test:watch": "node --test --watch test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "receiver": "node src/bin/mirror-and-test.ts",
    "dispatch": "node src/bin/dispatch-and-watch.ts",
    "cleanup": "node src/bin/cleanup.ts"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
