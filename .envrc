# Hermetic dev workbench (see CLAUDE.md "Run locally"). Puts the Bazel-managed tools — yamllint,
# golangci-lint, go — on PATH, so the commands CI runs work locally with no host installs.
# Enable direnv's shell hook (https://direnv.net/docs/hook.html), then `direnv allow`.
# Regenerate the bin dir after editing the tool set with: bazel run //tools:bazel_env
watch_file bazel-out/bazel_env-opt/bin/tools/bazel_env/bin
PATH_add bazel-out/bazel_env-opt/bin/tools/bazel_env/bin
if [[ ! -d bazel-out/bazel_env-opt/bin/tools/bazel_env/bin ]]; then
  log_error "ERROR[bazel_env.bzl]: Run 'bazel run //tools:bazel_env' to regenerate bazel-out/bazel_env-opt/bin/tools/bazel_env/bin"
fi
